{
    "manifest_version": 3,
    "name": "Gif search Extension",
    "author": "Klysman08",
    "homepage_url": "https://github.com/Klysman08",
    "version": "2.0",
    "description": "Search for images without leaving the page.",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "images/icon16.png",
            "48": "images/icon48.png",
            "128": "images/icon128.png"
        }
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "icons": {
        "16": "images/icon16.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
    },
    "permissions": [
        "activeTab",
        "storage" 
    ],
    "host_permissions": [
        "https://tenor.googleapis.com/*"
    ],
    "web_accessible_resources": [
        {
            "resources": ["images/*"],
            "matches": ["<all_urls>"]
        }
    ],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+Y"
            }
        }
    }
}
